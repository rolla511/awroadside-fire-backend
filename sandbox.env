AW_DB_STRICT=false
PUBLIC_BASE_URL=http://localhost:3000
PORT=3000

# Mapbox
MAPBOX_ACCESS_TOKEN=pk.sandbox_mock_token

# PayPal
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=mock_client_id
