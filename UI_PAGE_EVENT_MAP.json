{
  "version": "2026-04-27",
  "purpose": "Accurate page-to-event and endpoint mapping for the current AW Roadside web flow.",
  "authorityFiles": {
    "frontendController": "web/app.js",
    "backendEntrypoint": "backend/server.mjs",
    "securityController": "backend/aw-roadside-security.mjs",
    "providerWalletController": "backend/provider-wallet-controller.mjs"
  },
  "coverageEstimate": {
    "customer": 70,
    "provider": 62,
    "admin": 74
  },
  "pageFamilies": {
    "customer": [
      "web/home.html",
      "web/customer.html",
      "web/subscriber-access.html"
    ],
    "provider": [
      "web/provider.html",
      "web/provider-info.html",
      "web/provider-work.html",
      "web/provider-wallet.html"
    ],
    "admin": [
      "web/admin.html",
      "web/admin-dashboard.html",
      "web/admin-accounts.html",
      "web/admin-financials.html"
    ]
  },
  "pages": {
    "web/home.html": {
      "role": "public-entry",
      "state": "partial",
      "sourceHandlers": [
        "initializeApp",
        "loadFrontendConfig",
        "setupHomeAuth"
      ],
      "events": [
        {
          "event": "service-health-load",
          "elementId": "backend-status",
          "handler": "loadFrontendConfig",
          "request": {
            "method": "GET",
            "endpoint": "/api/aw-roadside/health"
          },
          "result": "implemented"
        },
        {
          "event": "frontend-config-load",
          "elementId": "api-status",
          "handler": "loadFrontendConfig",
          "request": {
            "method": "GET",
            "endpoint": "/api/aw-roadside/frontend-config"
          },
          "result": "implemented"
        },
        {
          "event": "member-sign-in",
          "elementId": "signin-form",
          "handler": "setupHomeAuth",
          "request": {
            "method": "POST",
            "endpoint": "/api/aw-roadside/auth/login"
          },
          "result": "implemented"
        },
        {
          "event": "guest-entry",
          "elementId": null,
          "handler": "direct-link",
          "request": null,
          "navigation": "customer.html",
          "result": "implemented"
        }
      ],
      "gaps": [
        "No dedicated home-specific request summary widgets.",
        "No explicit public request-status retrieval from the home page."
      ]
    },
