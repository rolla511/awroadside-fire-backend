{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://10.0.2.2:3000"
      },
      "android": {
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://awroadside-fire-backend.onrender.com"
      },
      "android": {
        "image": "latest"
      }
    },
    "production": {
      "autoIncrement": true,
      "developmentClient": false,
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://awroadside-fire-backend.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
