# Environment Configuration for AW Roadside Fire
# Copy this file to .env and set the appropriate values.

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# URLs
PUBLIC_BASE_URL=https://your-app-name.onrender.com

# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database
AW_DB_MODE=external-db
AW_DB_STRICT=false

# PayPal Configuration
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# Mail Configuration
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_REQUIRE_STARTTLS=true
MAIL_USER=mailbox@example.com
MAIL_PASSWORD=your_mail_password
MAIL_FROM=mailbox@example.com
MAIL_REPLY_TO=mailbox@example.com

# Security
# A random secret will be generated if not provided, but it's better to set a stable one for production.
AW_SESSION_SECRET=your_random_session_secret_here

# Admin Access
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
ADMIN_2FA_CODE=your_static_2fa_code
ADMIN_TRUSTED_ZONES=0.0.0.0/0

# Runtime Storage
# On Render, this should match your disk mount path.
RUNTIME_ROOT=/var/data/runtime
